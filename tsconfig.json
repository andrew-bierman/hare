{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "preserve",
		"incremental": true,
		"paths": {
			"web-app/*": ["./apps/web/src/*"],
			"@hare/db/schema": ["./packages/db/src/schema/index.ts"],
			"@hare/db": ["./packages/db/src/index.ts"],
			"@hare/agent/workers": ["./packages/agent/src/workers.ts"],
			"@hare/agent": ["./packages/agent/src/index.ts"],
			"@hare/config": ["./packages/config/src/index.ts"],
			"@hare/tools": ["./packages/tools/src/index.ts"],
			"@hare/types": ["./packages/types/src/index.ts"],
			"@hare/api": ["./packages/api/src/index.ts"],
			"@hare/auth/client": ["./packages/auth/src/client.ts"],
			"@hare/auth/server": ["./packages/auth/src/server.ts"],
			"@hare/auth": ["./packages/auth/src/index.ts"],
			"@hare/ui/*": ["./packages/ui/src/*"],
			"@hare/ui": ["./packages/ui/src/index.ts"],
			"@hare/app": ["./packages/app/index.ts"],
			"@hare/app/*": ["./packages/app/*"]
		},
		"types": ["bun"]
	},
	"include": [
		"apps/web/**/*.ts",
		"apps/web/**/*.tsx",
		"packages/**/*.ts",
		"packages/**/*.tsx",
		"apps/web/cloudflare-env.d.ts"
	],
	"exclude": ["node_modules", ".next", "dist", "apps/tauri", "packages/e2e"]
}
