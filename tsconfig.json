{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "preserve",
		"incremental": true,
		"baseUrl": ".",
		"paths": {
			"web-app/*": ["apps/web/src/*"],
			"@workspace/ui/*": ["packages/ui/src/*"],
			"@workspace/ui": ["packages/ui/src/index.ts"],
			"@hare/tools": ["packages/hare-tools/src/index.ts"],
			"@hare/tools/*": ["packages/hare-tools/src/*"],
			"@hare/agent": ["packages/hare-agent/src/index.ts"],
			"@hare/agent/*": ["packages/hare-agent/src/*"],
			"@hare/cli": ["packages/hare-cli/src/index.ts"]
		},
		"types": ["bun"]
	},
	"include": [
		"apps/**/*.ts",
		"apps/**/*.tsx",
		"packages/**/*.ts",
		"packages/**/*.tsx",
		"apps/web/cloudflare-env.d.ts"
	],
	"exclude": ["node_modules", ".next", "dist"]
}
