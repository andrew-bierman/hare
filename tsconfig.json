{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "preserve",
		"incremental": true,
		"baseUrl": ".",
		"paths": {
			"web-app/*": ["apps/web/src/*"],
			"@workspace/ui/*": ["packages/ui/src/*"],
			"@workspace/ui": ["packages/ui/src/index.ts"],
			"@hare/tools": ["packages/hare-tools/src/index.ts"],
			"@hare/tools/*": ["packages/hare-tools/src/*"],
			"@hare/agent": ["packages/hare-agent/src/index.ts"],
			"@hare/agent/*": ["packages/hare-agent/src/*"],
			"@hare/cli": ["packages/hare-cli/src/index.ts"],
			"@hare/api": ["packages/hare-api/src/index.ts"],
			"@hare/api/client": ["packages/hare-api/src/client.ts"],
			"@hare/api/services/*": ["packages/hare-api/src/services/*"],
			"@hare/api/*": ["packages/hare-api/src/*"],
			"@hare/app": ["packages/app/src/index.ts"],
			"@hare/app/*": ["packages/app/src/*"],
			"@app/*": ["packages/app/src/app/*"],
			"@pages/*": ["packages/app/src/pages/*"],
			"@widgets/*": ["packages/app/src/widgets/*"],
			"@shared/*": ["packages/app/src/shared/*"]
		},
		"types": ["bun"]
	},
	"include": [
		"apps/web/**/*.ts",
		"apps/web/**/*.tsx",
		"packages/**/*.ts",
		"packages/**/*.tsx",
		"apps/web/cloudflare-env.d.ts"
	],
	"exclude": ["node_modules", ".next", "dist", "apps/tauri", "packages/e2e"]
}
