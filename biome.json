{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noUselessFragments": "warn",
				"noForEach": "warn"
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"noUndeclaredDependencies": "warn"
			},
			"style": {
				"noNonNullAssertion": "warn",
				"useConst": "error",
				"noParameterAssign": "error",
				"useExportType": "error",
				"useImportType": "error",
				"useNumberNamespace": "error",
				"useDefaultSwitchClause": "warn"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noArrayIndexKey": "warn",
				"noAssignInExpressions": "warn",
				"noConsole": "warn",
				"noDoubleEquals": "error",
				"noEmptyBlockStatements": "warn"
			},
			"performance": {
				"noBarrelFile": "warn",
				"noReExportAll": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded"
		}
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"apps/**/*.ts",
			"apps/**/*.tsx",
			"packages/**/*.ts",
			"packages/**/*.tsx",
			"**/*.json",
			"!**/routeTree.gen.ts"
		]
	},
	"overrides": [
		{
			"includes": [
				"packages/*/src/index.ts",
				"packages/*/src/workers.ts",
				"packages/tools/src/*/index.ts",
				"packages/agent/src/tools/*.ts",
				"packages/ui/src/components/instructions-editor/index.ts",
				"apps/web/src/lib/onboarding/index.ts"
			],
			"linter": {
				"rules": {
					"performance": {
						"noBarrelFile": "off",
						"noReExportAll": "off"
					}
				}
			}
		},
		{
			"includes": ["scripts/**/*.ts", "apps/tauri/scripts/**/*.ts", "apps/web/e2e/**/*.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off",
						"noEmptyBlockStatements": "off"
					}
				}
			}
		},
		{
			"includes": ["**/__tests__/**/*.ts", "**/*.test.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredDependencies": "off"
					}
				}
			}
		},
		{
			"includes": ["packages/app/**/index.ts", "packages/app/shared/lib/tanstack/**/*.ts"],
			"linter": {
				"rules": {
					"performance": {
						"noBarrelFile": "off",
						"noReExportAll": "off"
					}
				}
			}
		},
		{
			"includes": [
				"packages/api/src/elysia/index.ts",
				"packages/api/src/schemas/index.ts",
				"packages/api/src/services/index.ts",
				"packages/api/src/elysia/routes/embed.ts",
				"packages/db/src/schema/index.ts"
			],
			"linter": {
				"rules": {
					"performance": {
						"noBarrelFile": "off",
						"noReExportAll": "off"
					}
				}
			}
		}
	]
}
