{
	"name": "@hare/api",
	"version": "0.1.0",
	"description": "Hono API for Hare AI agents platform",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./client": {
			"types": "./src/client.ts",
			"import": "./src/client.ts"
		},
		"./types": {
			"types": "./src/types.ts",
			"import": "./src/types.ts"
		},
		"./schemas": {
			"types": "./src/schemas/index.ts",
			"import": "./src/schemas/index.ts"
		},
