{
	"name": "@hare/docs",
	"version": "0.1.0",
	"description": "Documentation generation and content for Hare",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./generator": {
			"types": "./src/generator.ts",
			"import": "./src/generator.ts"
		},
		"./content/*": "./content/*"
	},
	"bin": {
		"hare-docs": "./src/cli.ts"
	},
	"scripts": {
		"generate": "bun run src/cli.ts",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"typescript": "catalog:"
	},
	"devDependencies": {
		"@hare/typescript-config": "workspace:*",
		"@types/node": "catalog:"
	}
}
