{
	"name": "@hare/db",
	"version": "0.1.0",
	"description": "Database schema and types for Hare platform",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./schema": {
			"types": "./src/schema/index.ts",
			"import": "./src/schema/index.ts"
		},
		"./types": {
			"types": "./src/types.ts",
			"import": "./src/types.ts"
		}
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src"
	],
	"scripts": {
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hare/config": "workspace:*",
		"@hare/types": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:",
		"@hare/typescript-config": "workspace:*",
		"drizzle-orm": "catalog:",
		"drizzle-zod": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.0"
	}
}
