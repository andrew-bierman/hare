{
	"extends": "@workspace/typescript-config/react-library.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@workspace/ui/*": ["../ui/src/*"],
			"@workspace/ui": ["../ui/src/index.ts"]
		},
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"noEmit": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": ["node_modules", "dist"]
}
