{
	"name": "@hare/testing",
	"version": "0.1.0",
	"description": "Shared test utilities, factories, and mocks for Hare platform",
	"keywords": [
		"hare",
		"testing",
		"mocks",
		"factories",
		"fixtures"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./factories": {
			"types": "./src/factories/index.ts",
			"import": "./src/factories/index.ts"
		},
		"./mocks": {
			"types": "./src/mocks/index.ts",
			"import": "./src/mocks/index.ts"
		},
		"./mocks/cuid2": {
			"types": "./src/mocks/cuid2.ts",
			"import": "./src/mocks/cuid2.ts"
		},
		"./seeds": {
			"types": "./src/seeds/index.ts",
			"import": "./src/seeds/index.ts"
		}
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src"
	],
	"scripts": {
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hare/config": "workspace:*",
		"@hare/db": "workspace:*",
		"@hare/types": "workspace:*"
	},
	"devDependencies": {
		"@hare/typescript-config": "workspace:*",
		"drizzle-orm": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
