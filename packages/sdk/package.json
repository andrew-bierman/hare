{
	"name": "hareai",
	"version": "0.1.0",
	"description": "Hare SDK - Build AI agents on Cloudflare's edge network",
	"keywords": [
		"cloudflare",
		"workers",
		"ai",
		"agent",
		"sdk",
		"llm",
		"tools",
		"mcp"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./tools": {
			"import": "./dist/tools.js",
			"types": "./dist/tools.d.ts"
		},
		"./types": {
			"import": "./dist/types.js",
			"types": "./dist/types.d.ts"
		},
		"./workers": {
			"import": "./dist/workers.js",
			"types": "./dist/workers.d.ts"
		}
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"prepublishOnly": "bun run build",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hare/agent": "workspace:*",
		"@hare/tools": "workspace:*",
		"@hare/types": "workspace:*"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20251224.0",
		"@hare/typescript-config": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.25.1",
		"agents": "^0.3.0",
		"ai": "^6.0.3",
		"drizzle-orm": "^0.45.1",
		"tsup": "^8",
		"typescript": "^5",
		"zod": "^4.2.1"
	},
	"peerDependencies": {
		"@modelcontextprotocol/sdk": "^1.23.0",
		"agents": "^0.3.0",
		"ai": "^6.0.0",
		"drizzle-orm": "^0.45.1",
		"zod": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"@modelcontextprotocol/sdk": {
			"optional": true
		},
		"drizzle-orm": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/andrew-bierman/hare.git",
		"directory": "packages/sdk"
	},
	"homepage": "https://github.com/andrew-bierman/hare",
	"bugs": {
		"url": "https://github.com/andrew-bierman/hare/issues"
	}
}
