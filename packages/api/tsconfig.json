{
	"extends": "@workspace/typescript-config/base.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@hare/api/*": ["./src/*"],
			"web-app/*": ["../../apps/web/src/*"]
		},
		"types": ["@cloudflare/workers-types"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"]
}
