{
	"name": "@hare/api",
	"version": "0.1.0",
	"description": "Hono API for Hare AI agents platform",
	"keywords": [
		"cloudflare",
		"workers",
		"hono",
		"api",
		"ai",
		"agent"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./client": {
			"types": "./src/client.ts",
			"import": "./src/client.ts"
		},
		"./schemas": {
			"types": "./src/schemas/index.ts",
			"import": "./src/schemas/index.ts"
		},
		"./middleware": {
			"types": "./src/middleware/index.ts",
			"import": "./src/middleware/index.ts"
		},
		"./routes": {
			"types": "./src/routes/index.ts",
			"import": "./src/routes/index.ts"
		},
		"./helpers": {
			"types": "./src/helpers/index.ts",
			"import": "./src/helpers/index.ts"
		},
		"./services": {
			"types": "./src/services/index.ts",
			"import": "./src/services/index.ts"
		}
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src",
		"README.md"
	],
	"scripts": {
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@elithrar/workers-hono-rate-limit": "catalog:",
		"@hare/agent": "workspace:*",
		"@hare/auth": "workspace:*",
		"@hare/config": "workspace:*",
		"@hare/db": "workspace:*",
		"@hare/email": "workspace:*",
		"@hare/security": "workspace:*",
		"@hare/tools": "workspace:*",
		"@hare/types": "workspace:*",
		"@orpc/client": "^1.13.2",
		"@orpc/server": "^1.13.2",
		"@react-email/components": "catalog:",
		"@scalar/hono-api-reference": "catalog:",
		"resend": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:",
		"@hare/typescript-config": "workspace:*",
		"@hono/zod-openapi": "catalog:",
		"ai": "catalog:",
		"drizzle-orm": "catalog:",
		"hono": "catalog:",
		"stripe": "catalog:",
		"typescript": "catalog:",
		"zod": "catalog:"
	},
	"peerDependencies": {
		"@hono/zod-openapi": "^1.2.0",
		"ai": "^6.0.0",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.0.0",
		"stripe": "^20.0.0",
		"zod": "^4.0.0"
	}
}
