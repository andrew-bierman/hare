{
	"name": "@hare/types",
	"version": "0.1.0",
	"description": "Shared type definitions for Hare platform",
	"keywords": [
		"hare",
		"types",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./agent": {
			"types": "./src/agent.ts",
			"import": "./src/agent.ts"
		},
		"./db": {
			"types": "./src/db.ts",
			"import": "./src/db.ts"
		},
		"./tool": {
			"types": "./src/tool.ts",
			"import": "./src/tool.ts"
		},
		"./api": {
			"types": "./src/api.ts",
			"import": "./src/api.ts"
		},
		"./ai": {
			"types": "./src/ai.ts",
			"import": "./src/ai.ts"
		},
		"./cloudflare": {
			"types": "./src/cloudflare.ts",
			"import": "./src/cloudflare.ts"
		}
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src"
	],
	"dependencies": {
		"@elithrar/workers-hono-rate-limit": "^0.5.1",
		"ai": "^6.0.3",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20251224.0",
		"@hare/typescript-config": "workspace:*",
		"typescript": "^5"
	}
}
