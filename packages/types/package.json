{
	"name": "@hare/types",
	"version": "0.1.0",
	"description": "Shared type definitions for Hare platform",
	"keywords": [
		"hare",
		"types",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./agent": {
			"types": "./src/agent.ts",
			"import": "./src/agent.ts"
		},
		"./db": {
			"types": "./src/db.ts",
			"import": "./src/db.ts"
		},
		"./tool": {
			"types": "./src/tool.ts",
			"import": "./src/tool.ts"
		},
		"./api": {
			"types": "./src/api.ts",
			"import": "./src/api.ts"
		},
		"./ai": {
			"types": "./src/ai.ts",
			"import": "./src/ai.ts"
		},
		"./cloudflare": {
			"types": "./src/cloudflare.ts",
			"import": "./src/cloudflare.ts"
		},
		"./cloudflare-test": {
			"types": "./src/cloudflare-test.d.ts"
		}
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src",
		"src/cloudflare-test.d.ts"
	],
	"scripts": {
		"lint": "biome check .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@elithrar/workers-hono-rate-limit": "catalog:",
		"ai": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:",
		"@hare/typescript-config": "workspace:*",
		"typescript": "catalog:"
	}
}
