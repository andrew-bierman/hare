{
	"name": "@hare/api-client",
	"version": "0.1.0",
	"description": "Type-safe Hono RPC client for Hare API",
	"keywords": [
		"hono",
		"client",
		"rpc",
		"api",
		"typescript"
	],
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./orpc": {
			"types": "./src/orpc.ts",
			"import": "./src/orpc.ts"
		}
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"src"
	],
	"dependencies": {
		"@hare/api": "workspace:*",
		"@orpc/client": "^1.13.2",
		"@orpc/server": "^1.13.2"
	},
	"devDependencies": {
		"@hare/typescript-config": "workspace:*",
		"hono": "^4.11.3",
		"typescript": "^5"
	},
	"peerDependencies": {
		"hono": "^4.0.0"
	}
}
