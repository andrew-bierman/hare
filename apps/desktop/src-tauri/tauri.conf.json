{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Hare",
	"version": "0.1.0",
	"identifier": "com.hare.desktop",
	"build": {
		"beforeDevCommand": "cd ../web && SKIP_CF_DEV=true bun run dev",
		"devUrl": "http://localhost:3000",
		"beforeBuildCommand": "cd ../web && TAURI_BUILD=true bun run build",
		"frontendDist": "../web/out"
	},
	"app": {
		"withGlobalTauri": false,
		"windows": [
			{
				"title": "Hare",
				"width": 1200,
				"height": 800,
				"minWidth": 800,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"minimumSystemVersion": "10.13"
		}
	}
}
