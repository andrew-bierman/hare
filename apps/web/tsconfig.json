{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"plugins": [{ "name": "next" }],
		"baseUrl": "../..",
		"paths": {
			"#db/*": ["apps/web/src/db/*"],
			"#api/*": ["apps/web/src/lib/api/*"],
			"#components/*": ["apps/web/src/components/*"],
			"#lib/*": ["apps/web/src/lib/*"],
			"#hooks/*": ["apps/web/src/hooks/*"]
		},
		"types": ["./cloudflare-env.d.ts", "node"]
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		"cloudflare-env.d.ts"
	],
	"exclude": ["node_modules"]
}
