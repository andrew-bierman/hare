{
	"extends": "@workspace/typescript-config/nextjs.json",
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"web-app/*": ["./src/*"],
			"@workspace/ui/*": ["../../packages/ui/src/*"]
		},
		"types": ["node"],
		"plugins": [{ "name": "next" }]
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "cloudflare-env.d.ts"],
	"exclude": ["node_modules", "**/__tests__/**"]
}
