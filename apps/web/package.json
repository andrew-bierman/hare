{
	"name": "web-app",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "bun run docs:generate && NODE_OPTIONS='--max-old-space-size=4096' vite build",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:local": "wrangler d1 migrations apply hare-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply hare-db --remote",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"deploy": "bun run build && wrangler deploy",
		"dev": "vite dev",
		"docs:generate": "bun run ../../packages/docs/src/cli.ts --verbose && cp -r ../../packages/docs/content/_generated/* content/sdk/_generated/",
		"lint": "biome check .",
		"preview": "bun run build && vite preview",
		"start": "bun .output/server/index.mjs",
		"test": "E2E=true playwright test",
		"test:headed": "E2E=true playwright test --headed",
		"test:ui": "E2E=true playwright test --ui",
		"typecheck": "tsc --noEmit",
		"upload": "wrangler deploy"
	},
