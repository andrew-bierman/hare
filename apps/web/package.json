{
	"name": "web-app",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"build:cloudflare": "opennextjs-cloudflare build",
		"start": "next start",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars",
		"upload": "opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare upload",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:migrate:local": "wrangler d1 migrations apply hare-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply hare-db --remote",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:headed": "playwright test --headed"
	},
	"dependencies": {
		"@ai-sdk/provider": "^2.0.0",
		"@ai-sdk/provider-utils": "^3.0.19",
		"agents": "0.0.67",
		"@hono/zod-openapi": "^1.1.5",
		"@hono/zod-validator": "^0.7.5",
		"@opennextjs/cloudflare": "^1.14.4",
		"@paralleldrive/cuid2": "^2.2.2",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@scalar/hono-api-reference": "^0.9.28",
		"@tanstack/react-form": "^1.27.4",
		"@tanstack/react-query": "^5.90.12",
		"@tanstack/react-query-devtools": "^5.91.1",
		"@workspace/ui": "workspace:*",
		"ai": "^5.0.115",
		"better-auth": "^1.4.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.38.0",
		"drizzle-zod": "^0.8.3",
		"hono": "^4.11.1",
		"lucide-react": "^0.561.0",
		"next": "15.5.9",
		"next-themes": "^0.4.6",
		"react": "19.1.4",
		"react-dom": "19.1.4",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0",
		"workers-ai-provider": "^2.0.0",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20251217.0",
		"@workspace/typescript-config": "workspace:*",
		"@playwright/test": "^1.57.0",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^25.0.2",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"drizzle-kit": "^0.30.0",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5",
		"wrangler": "^4.54.0"
	}
}
