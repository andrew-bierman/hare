# ☁️ Cloudflare Workers Local Development Variables
# 
# 🤖 This file is autogenerated by .github/scripts/env.ts from the root .env.local file.
# DO NOT edit this file directly. Instead:
# 1. Edit the root .env.local file
# 2. Run: bun install
# 
# 💡 Note: Cloudflare Workers uses .dev.vars instead of .env for local development.
# Public variables (NEXT_PUBLIC_*) are excluded as they're client-side only.

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=

# Auth (Better Auth)
BETTER_AUTH_SECRET=         # Generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:8787

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx

# Development
NODE_ENV=development
