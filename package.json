{
	"name": "hare",
	"type": "module",
	"private": true,
	"packageManager": "bun@1.3.5",
	"workspaces": [
		"apps/*",
		"packages/*",
		"scripts"
	],
	"scripts": {
		"postinstall": "bun run scripts/env.ts",
		"dev": "turbo dev",
		"build": "turbo build",
		"start": "bun run --cwd apps/web start",
		"preview": "bun run --cwd apps/web preview",
		"deploy": "bun run --cwd apps/web deploy",
		"upload": "bun run --cwd apps/web upload",
		"tauri:dev": "bun run --cwd apps/tauri tauri:dev",
		"tauri:build": "bun run --cwd apps/tauri tauri:build",
		"tauri:sync-routes": "bun run scripts/sync-tauri-routes.ts",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"checks": "bun run scripts/checks.ts",
		"typecheck": "tsc -b",
		"typecheck:web": "bun run --cwd apps/web tsc --noEmit",
		"db:generate": "bun run --cwd apps/web db:generate",
		"db:migrate": "bun run --cwd apps/web db:migrate",
		"db:migrate:local": "wrangler d1 migrations apply hare-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply hare-db --remote",
		"db:push": "bun run --cwd apps/web db:push",
		"db:studio": "bun run --cwd apps/web db:studio",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:unit": "vitest run --filter unit",
		"test:workers": "vitest run --config vitest.workers.config.ts",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"cf:typegen": "bun run --cwd apps/web cf-typegen",
		"clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/.next apps/*/.open-next",
		"clean:cache": "rm -rf apps/*/.next apps/*/.open-next .turbo",
		"deps": "bun run scripts/deps.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@cloudflare/vitest-pool-workers": "^0.11.1",
		"@types/bun": "latest",
		"@types/node": "^22.19.3",
		"@vitest/coverage-v8": "^3.2.4",
		"miniflare": "^4.20251217.0",
		"turbo": "^2.7.2",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4",
		"wrangler": "^4.56.0"
	},
	"dependencies": {
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.13"
	}
}
