{
	"name": "hare",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*",
		"scripts"
	],
	"scripts": {
		"build": "turbo build",
		"build:tauri": "turbo build --filter=hare-tauri",
		"build:web": "turbo build --filter=web-app",
		"cf:typegen": "bun run --cwd apps/web cf-typegen",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"check-catalog": "bun run scripts/check-catalog.ts",
		"check-catalog:fix": "bun run scripts/check-catalog.ts --fix",
		"check-deps": "bun run --cwd scripts check-deps",
		"checks": "bun run scripts/checks.ts",
		"clean": "bun run scripts/clean.ts",
		"clean:all": "bun run scripts/clean.ts --all",
		"clean:cache": "bun run scripts/clean.ts --cache",
		"clean:deps": "bun run scripts/clean.ts --deps",
		"clean:install": "bun run scripts/clean.ts --all && bun install",
		"db:generate": "bun run --cwd apps/web db:generate",
		"db:migrate": "bun run --cwd apps/web db:migrate",
		"db:migrate:local": "bun run --cwd apps/web db:migrate:local",
		"db:migrate:remote": "bun run --cwd apps/web db:migrate:remote",
		"db:push": "bun run --cwd apps/web db:push",
		"db:studio": "bun run --cwd apps/web db:studio",
		"deploy": "bun run --cwd apps/web deploy",
		"deps": "bun run scripts/deps.ts",
		"dev": "turbo dev",
		"fix-deps": "bun run --cwd scripts fix-deps",
		"format": "biome format --write .",
		"postinstall": "bun run scripts/env.ts",
		"lint": "turbo lint",
		"lint:custom": "bun run scripts/lint-custom.ts",
		"lint:custom:report": "bun run scripts/lint-custom.ts --report",
		"lint:fix": "biome lint --write .",
		"preview": "bun run --cwd apps/web preview",
		"setup:worktree": "bun run scripts/setup-worktree.ts",
		"sort-packages": "bun run scripts/sort-packages.ts",
		"sort-packages:check": "bun run scripts/sort-packages.ts --check",
		"start": "bun run --cwd apps/web start",
		"tauri:build": "bun run --cwd apps/tauri tauri:build",
		"tauri:dev": "bun run --cwd apps/tauri tauri:dev",
		"tauri:sync-routes": "bun run scripts/sync-tauri-routes.ts",
		"test": "NODE_ENV=test vitest run",
		"test:coverage": "NODE_ENV=test vitest run --coverage",
		"test:e2e": "E2E=true bun run --cwd apps/web test",
		"test:ui": "vitest --ui",
		"test:unit": "NODE_ENV=test vitest run",
		"test:watch": "NODE_ENV=test vitest",
		"typecheck": "turbo typecheck",
		"typecheck:tsc": "tsc -b",
		"typecheck:tsgo": "tsgo -b",
		"typecheck:web": "bun run --cwd apps/web tsc --noEmit",
		"upload": "bun run --cwd apps/web upload",
		"version": "bun run scripts/version.ts"
	},
	"overrides": {
		"@modelcontextprotocol/sdk": "1.25.1",
		"esbuild": "^0.25.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"@cloudflare/vitest-pool-workers": "^0.11.1",
		"@cloudflare/workers-types": "catalog:",
		"@types/bun": "latest",
		"@types/node": "catalog:",
		"@typescript/native-preview": "^7.0.0-dev.20251228.1",
		"@vitest/coverage-v8": "^3.2.4",
		"miniflare": "^4.20251217.0",
		"turbo": "^2.7.2",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	},
	"packageManager": "bun@1.3.5",
	"catalog": {
		"@cloudflare/workers-types": "^4.20251224.0",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language-data": "^6.5.2",
		"@codemirror/view": "^6.39.7",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@elithrar/workers-hono-rate-limit": "^0.5.1",
		"@modelcontextprotocol/sdk": "^1.25.1",
		"@paralleldrive/cuid2": "^3.0.6",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@react-email/components": "^1.0.3",
		"@scalar/hono-api-reference": "^0.9.30",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/db": "^0.5.16",
		"@tanstack/query-db-collection": "^1.0.12",
		"@tanstack/react-db": "^0.1.60",
		"@tanstack/react-form": "^1.27.6",
		"@tanstack/react-query": "^5.90.14",
		"@tanstack/react-query-devtools": "^5.91.2",
		"@tanstack/react-router": "^1.144.0",
		"@tanstack/react-start": "^1.145.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.13",
		"@tanstack/zod-form-adapter": "^0.42.1",
		"@types/node": "^25.0.3",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@uiw/react-codemirror": "^4.25.4",
		"@vitejs/plugin-react": "^5.1.2",
		"agents": "^0.3.0",
		"ai": "^6.0.3",
		"better-auth": "^1.4.9",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"gpt-tokenizer": "^3.4.0",
		"hono": "^4.11.3",
		"lucide-react": "^0.562.0",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"recharts": "^3.6.0",
		"resend": "^6.6.0",
		"sonner": "^2.0.7",
		"stripe": "^20.1.0",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5",
		"vite": "^7.3.0",
		"vitest": "^3.2.4",
		"workers-ai-provider": "^3.1.10",
		"zod": "^4.2.1"
	}
}
