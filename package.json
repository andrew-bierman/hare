{
  "name": "hare",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "bun run --cwd apps/web start",
    "preview": "bun run --cwd apps/web preview",
    "deploy": "bun run --cwd apps/web deploy",
    "upload": "bun run --cwd apps/web upload",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "checks": "bun run lint && bun run typecheck && bun run build",
    "typecheck": "tsc -b",
    "typecheck:web": "bun run --cwd apps/web tsc --noEmit",
    "db:generate": "bun run --cwd apps/web db:generate",
    "db:migrate": "bun run --cwd apps/web db:migrate",
    "db:migrate:local": "wrangler d1 migrations apply hare-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hare-db --remote",
    "db:push": "bun run --cwd apps/web db:push",
    "db:studio": "bun run --cwd apps/web db:studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --filter unit",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "cf:typegen": "bun run --cwd apps/web cf-typegen",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/.next apps/*/.open-next",
    "clean:cache": "rm -rf apps/*/.next apps/*/.open-next .turbo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.9",
    "@cloudflare/vitest-pool-workers": "^0.11.1",
    "@cloudflare/workers-types": "^4.20251216.0",
    "@playwright/test": "^1.48.0",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^3.2.4",
    "miniflare": "^4.20251210.0",
    "turbo": "^2.6.3",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4",
    "wrangler": "^3.90.0"
  }
}
