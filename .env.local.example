# 🐇 Hare Environment Variables
#
# 💡 Copy this file to .env.local and fill in your values:
#    cp .env.local.example .env.local
#
# 🤖 The postinstall script will automatically generate:
#    - apps/web/.env.local (for Vite)
#    - apps/web/.dev.vars (for Cloudflare Workers)

# =============================================================================
# CLOUDFLARE
# =============================================================================

# Account ID (get from: wrangler whoami)
CLOUDFLARE_ACCOUNT_ID=a0adf59e1ef3edc3d2bbc2ff272474bc

# D1 Database ID (from wrangler.jsonc)
CLOUDFLARE_D1_DATABASE_ID=ddeb776f-4f19-4be2-8178-0dbd8e216c5a

# API Token for D1 access (required for: drizzle-kit studio, db:push, db:migrate:remote)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: D1 Edit, Account Settings Read
CLOUDFLARE_D1_TOKEN=

# =============================================================================
# AUTH (Better Auth)
# =============================================================================

# Session encryption secret - Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Auth service URL (same as app URL - everything runs on one port)
BETTER_AUTH_URL=http://localhost:3000

# =============================================================================
# APP
# =============================================================================

# Public application URL (used for redirects, CORS, etc.)
# Note: API and app run on the same port via Cloudflare Vite plugin
VITE_APP_URL=http://localhost:3000

# Application URL for Cloudflare Workers (without VITE_ prefix)
# Required for auth/CORS - Cloudflare Workers excludes VITE_ prefixed vars
APP_URL=http://localhost:3333

# =============================================================================
# OAUTH PROVIDERS (optional - social login disabled if not set)
# =============================================================================

# Google OAuth - https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth - https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# =============================================================================
# STRIPE (optional - billing features disabled if not set)
# =============================================================================

# API keys - https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs for subscription plans
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_TEAM=price_xxx

# =============================================================================
# FEATURE FLAGS (optional - defaults shown)
# =============================================================================

# AI Chat
# FEATURE_AI_CHAT=true
# FEATURE_AI_CHAT_BETA_MODE=false
# FEATURE_AI_CHAT_ALLOWED_EMAILS=user1@example.com,user2@example.com
