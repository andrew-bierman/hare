# 🐇 Hare Environment Variables
# 
# 💡 Copy this file to .env.local and fill in your values:
#    cp .env.local.example .env.local
# 
# 🤖 The postinstall script will automatically generate:
#    - apps/web/.env.local (for Next.js)
#    - apps/web/.dev.vars (for Cloudflare Workers)

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
D1_DATABASE_ID=

# Auth (Better Auth)
BETTER_AUTH_SECRET=         # Generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:8787

# Feature Flags
ENABLE_AI_CHAT=true                                    # Set to 'false' to disable AI chat globally
AI_CHAT_BETA_MODE=false                                # Set to 'true' to restrict to specific users
AI_CHAT_ALLOWED_EMAILS=user1@example.com,user2@example.com  # Comma-separated emails (when beta mode enabled)

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_TEAM=price_xxx

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787

# Development
NODE_ENV=development
