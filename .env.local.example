# 🐇 Hare Environment Variables
#
# 💡 Copy this file to .env.local and fill in your values:
#    cp .env.local.example .env.local
#
# 🤖 The postinstall script will automatically generate:
#    - apps/web/.env.local (for Next.js)
#    - apps/web/.dev.vars (for Cloudflare Workers)

# =============================================================================
# REQUIRED - Local Development
# =============================================================================

# Cloudflare (get from: wrangler whoami)
CLOUDFLARE_ACCOUNT_ID=

# Auth - Generate secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8787

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# OPTIONAL - Features disabled if not set
# =============================================================================

# OAuth Providers (social login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Stripe (billing features)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_TEAM=price_xxx

# =============================================================================
# OPTIONAL - Feature Flags (defaults shown)
# =============================================================================

# ENABLE_AI_CHAT=true
# AI_CHAT_BETA_MODE=false
# AI_CHAT_ALLOWED_EMAILS=user1@example.com,user2@example.com
